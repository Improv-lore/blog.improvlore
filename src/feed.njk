---
permalink: /feed.xml
eleventyExcludeFromCollections: true
---
{%- set posts = collections.post | reverse -%}
<?xml version="1.0" encoding="utf-8"?>
<feed xmlns="http://www.w3.org/2005/Atom">
  <title>{{ site.name }}</title>
  <subtitle>{{ site.description }}</subtitle>
  <link href="{{ site.absUrl('/feed.xml') }}" rel="self"/>
  <link href="{{ site.url }}/"/>
  <updated>{% if posts | length %}{{ posts[0].date | dateToRfc3339 }}{% else %}{{ site.year }}-01-01T00:00:00Z{% endif %}</updated>
  <id>{{ site.url }}/</id>
  <author><name>Improv Lore</name></author>
  {%- for post in posts %}
  <entry>
    <title>{{ post.data.title }}</title>
    <link href="{{ site.absUrl(post.url) }}"/>
    <updated>{{ post.date | dateToRfc3339 }}</updated>
    <id>{{ site.absUrl(post.url) }}</id>
    <summary>{{ post.data.description or (post.templateContent | excerpt(280)) }}</summary>
    <content type="html">{{ post.templateContent }}</content>
  </entry>
  {%- endfor %}
</feed>
