---
layout: base.njk
ogType: article
eleventyComputed:
  # One normalized [{name, url}] list drives both the byline and the JSON-LD
  # below, so single- and multi-author posts render consistently.
  authorList: "{{ authors | authorList(author, authorUrl) | dump | safe }}"
  # Built here (not in the body) so the value propagates up to base.njk's <head>;
  # a {% set %} in the template body would not be visible to the parent layout.
  jsonLd: >-
    {% set people = authors | authorList(author, authorUrl) %}
    {
      "@context": "https://schema.org",
      "@type": "BlogPosting",
      "headline": {{ title | dump | safe }},
      "datePublished": "{{ page.date | isoDate }}",
      "dateModified": "{{ page.date | isoDate }}",
      "author": {% if people.length %}[{% for p in people %}{ "@type": "Person", "name": {{ p.name | dump | safe }}{% if p.url %}, "url": {{ p.url | dump | safe }}{% endif %} }{% if not loop.last %}, {% endif %}{% endfor %}]{% else %}{ "@type": "Organization", "name": "Improv Lore" }{% endif %},
      "publisher": {
        "@type": "Organization",
        "name": "Improv Lore",
        "logo": { "@type": "ImageObject", "url": "{{ site.absUrl('/assets/icon-512.png') }}" }
      },
      "mainEntityOfPage": "{{ site.absUrl(page.url) }}"{% if cover %},
      "image": "{{ site.absUrl(cover) }}"{% endif %}
    }
---
{# A post renders inside the events-root shell (same container the main site
   uses) so the frosted background and gutters line up. Cover image, then a
   title block with byline + tags, then the rendered Markdown body. #}
{% set canonicalUrl = page.url %}

<article class="events-root post">
  {% if republished %}
  {# Republished post: an earlier piece from another writer's own blog/Substack,
     re-hosted here. Credit the original author and link back to the source. #}
  <aside class="repost-banner" role="note">
    <span class="repost-banner-icon" aria-hidden="true">↻</span>
    <p class="repost-banner-text">
      This is an earlier post, originally published
      {% if originalAuthor %}by
        {% if originalUrl %}<a href="{{ originalUrl }}" target="_blank" rel="noopener">{{ originalAuthor }}</a>{% else %}{{ originalAuthor }}{% endif %}{% endif %}
      on {% if originalUrl and not originalAuthor %}<a href="{{ originalUrl }}" target="_blank" rel="noopener">{{ originalSource or "their own blog" }}</a>{% else %}{{ originalSource or "their own blog" }}{% endif %}.
      {% if originalUrl and originalAuthor %}<a class="repost-banner-link" href="{{ originalUrl }}" target="_blank" rel="noopener">Read the original ↗</a>{% endif %}
    </p>
  </aside>
  {% endif %}

  {% if cover %}
  <figure class="post-cover">
    <img src="{{ cover }}" alt="{{ coverAlt or title }}" loading="eager" fetchpriority="high"{% if 'http' in cover %} eleventy:ignore{% endif %}>
    {% if coverCaption %}<figcaption>{{ coverCaption }}</figcaption>{% endif %}
  </figure>
  {% endif %}

  <header class="post-header">
    {% if tags %}
    <ul class="post-tags" aria-label="Topics">
      {% for tag in tags %}{% if tag not in ["post", "posts", "all"] %}
      <li><a class="post-tag" href="/tags/{{ tag | slugify }}/">{{ tag }}</a></li>
      {% endif %}{% endfor %}
    </ul>
    {% endif %}

    <h1 class="post-title">{{ title }}</h1>

    <p class="post-meta">
      {% set people = authors | authorList(author, authorUrl) %}
      {% if people.length %}
      <span class="post-author">Written by{% for p in people %}
          {%- if loop.first %} {% elif loop.last %}{% if people.length > 2 %},{% endif %} and {% else %}, {% endif -%}
          {%- if p.url %}<a class="post-author-link" href="{{ p.url }}"{% if 'http' in p.url %} target="_blank" rel="noopener"{% endif %}>{{ p.name }}</a>{% else %}{{ p.name }}{% endif -%}
        {% endfor %}</span>
      <span class="post-meta-sep" aria-hidden="true">·</span>
      {% endif %}
      <time datetime="{{ page.date | isoDate }}">{{ page.date | readableDate }}</time>
      <span class="post-meta-sep" aria-hidden="true">·</span>
      <span>{{ content | readingTime }} min read</span>
    </p>
  </header>

  <div class="post-body">
    {{ content | safe }}
  </div>

  {% if photoCredit %}
  <p class="post-photo-credit">Photos by
    {% if photoCreditUrl %}<a href="{{ photoCreditUrl }}"{% if 'http' in photoCreditUrl %} target="_blank" rel="noopener"{% endif %}>{{ photoCredit }}</a>{% else %}{{ photoCredit }}{% endif %}
  </p>
  {% endif %}

  <footer class="post-footer">
    <a class="btn btn-primary" href="/">← Back to all posts</a>
    <a class="btn btn-secondary" href="{{ site.mainSite }}/events/" target="_blank" rel="noopener">Check out our upcoming events →</a>
  </footer>
</article>
