<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{{ title }}</title>
  {% set desc = pageDescription or site.description %}
  <meta name="description" content="{{ desc }}">
  <link rel="canonical" href="{{ site.absUrl(canonicalUrl or page.url) }}">
  <meta property="og:title" content="{{ title }}">
  <meta property="og:description" content="{{ desc }}">
  <meta property="og:url" content="{{ site.absUrl(page.url) }}">
  <meta property="og:site_name" content="{{ site.name }}">
  {% set ogImage = pageImage or cover or "/assets/logo.png" %}
  {% set ogImageUrl = site.absUrl(ogImage) | ogCard %}
  <meta property="og:image" content="{{ ogImageUrl }}">
  <meta property="og:image:alt" content="{{ coverAlt or title }}">
  {%- if (pageImage or cover) and 'img.improvlore.com' in ogImageUrl %}
  {# ogCard forces a 1200×630 card crop for img.improvlore.com covers, so the
     declared dimensions are exact. Skipped for the logo fallback / other hosts. #}
  <meta property="og:image:width" content="1200">
  <meta property="og:image:height" content="630">
  {%- endif %}
  <meta property="og:type" content="{{ ogType or 'website' }}">
  <meta name="twitter:card" content="{% if pageImage or cover %}summary_large_image{% else %}summary{% endif %}">
  <meta name="twitter:image" content="{{ ogImageUrl }}">
  <meta name="twitter:image:alt" content="{{ coverAlt or title }}">
  <link rel="icon" href="/assets/favicon.svg" type="image/svg+xml">
  <link rel="icon" href="/assets/favicon.ico" sizes="any">
  <link rel="apple-touch-icon" href="/assets/apple-touch-icon.png">
  <link rel="manifest" href="/manifest.webmanifest">
  <link rel="alternate" type="application/atom+xml" title="Improv Lore Blog" href="/feed.xml">
  {% if jsonLd %}<script type="application/ld+json">{{ jsonLd | safe }}</script>{% endif %}
  <style>
    {{ "src/assets/css/base.css" | inlineCss | safe }}
    {{ "src/assets/css/motifs.css" | inlineCss | safe }}
    {{ "src/assets/css/components.css" | inlineCss | safe }}
    {{ "src/assets/css/blog.css" | inlineCss | safe }}
  </style>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link rel="preload" href="https://fonts.googleapis.com/css2?family=Archivo:wght@400;500;600;700&family=Bricolage+Grotesque:opsz,wght@12..96,600;12..96,700;12..96,800&display=swap" as="style" onload="this.onload=null;this.rel='stylesheet'">
  <noscript><link href="https://fonts.googleapis.com/css2?family=Archivo:wght@400;500;600;700&family=Bricolage+Grotesque:opsz,wght@12..96,600;12..96,700;12..96,800&display=swap" rel="stylesheet"></noscript>
</head>

<body>
  {# The full motif set. Each page shows only a rotating subset so the
     background doesn't read identically everywhere. The slice is derived from
     the page URL, so it's stable per page (no layout shift) but varies page to
     page. Index in this list maps to the motif-N positioning classes in CSS. #}
  {% set allMotifs = [
    "/assets/icons/lightning.png",
    "/assets/icons/starburst.png",
    "/assets/icons/star-purple.png",
    "/assets/icons/diamond.png",
    "/assets/icons/star-4point.png",
    "/assets/icons/moon.png",
    "/assets/icons/star-green.png",
    "/assets/icons/ring-pink.png",
    "/assets/icons/star-outline.png",
    "/assets/icons/arc-blue.png",
    "/assets/icons/arc-green.png",
    "/assets/icons/arc-pink.png",
    "/assets/icons/pacman-orange.png",
    "/assets/icons/pacman-yellow.png",
    "/assets/icons/blob-blue.png",
    "/assets/icons/blob-cream.png"
  ] %}
  {% set motifSeed = (page.url | length) %}
  <div class="page-motifs" aria-hidden="true">
    {% for src in allMotifs %}
      {% set n = loop.index0 %}
      {% set shown = ((n - motifSeed) % 16 + 16) % 16 %}
      {% if shown < 9 %}
      <img class="motif motif-{{ loop.index }}" src="{{ src }}" alt="" loading="lazy" decoding="async" eleventy:ignore>
      {% endif %}
    {% endfor %}
  </div>

  {# Frosted pane between the animated motifs and the page content, so the shapes
     read as a soft, blurred wash rather than competing with text. #}
  <div class="page-frost" aria-hidden="true"></div>

  <div class="foreground-motifs" aria-hidden="true">
    <img class="fg-motif fg-motif-lightning" src="/assets/icons/lightning.png"     alt="" loading="lazy" decoding="async" eleventy:ignore>
    <img class="fg-motif fg-motif-pacman"    src="/assets/icons/pacman-yellow.png" alt="" loading="lazy" decoding="async" eleventy:ignore>
  </div>

  {# Top bar: logo left, nav right. The logo points at the blog home; the last
     nav item points back at the main improvlore.com site so the blog reads as
     part of it. #}
  {% set navLinks = [
    { url: "/tags/", label: "Topics" },
    { url: "/community/", label: "Community" },
    { url: site.mainSite, label: "improvlore.com ↗", external: true }
  ] %}
  <header class="site-header" role="banner">
    <a class="site-header-logo" href="/" aria-label="Improv Lore blog home page">
      <img class="hero-logo" src="/assets/logo.png" alt="Improv Lore" width="245" height="36" eleventy:ignore>
      <span class="site-header-tagline">Blog</span>
    </a>
    <button class="site-nav-toggle" type="button" aria-expanded="false" aria-controls="site-nav" aria-label="Open menu">
      <span class="site-nav-toggle-bars" aria-hidden="true"></span>
    </button>
    <nav class="site-nav" id="site-nav" aria-label="Main navigation">
      {% for link in navLinks %}
      <a class="site-nav-link{% if not link.external and page.url == link.url %} is-active{% endif %}" href="{{ link.url }}"{% if link.external %} target="_blank" rel="noopener"{% elif page.url == link.url %} aria-current="page"{% endif %}>{{ link.label }}</a>
      {% endfor %}
    </nav>
  </header>

  <main>
    {{ content | safe }}
  </main>

  <footer class="footer">
    <div class="footer-inner">
      <div class="footer-cols">
        <nav class="footer-col" aria-label="Blog">
          <h3 class="footer-col-title">Blog</h3>
          <a href="/">All posts</a>
          <a href="/tags/">Topics</a>
          <a href="/community/">Community</a>
          <a href="/feed.xml">RSS feed</a>
        </nav>

        <nav class="footer-col" aria-label="Improv Lore">
          <h3 class="footer-col-title">Improv Lore</h3>
          <a href="{{ site.mainSite }}/" target="_blank" rel="noopener">Home</a>
          <a href="{{ site.mainSite }}/events/" target="_blank" rel="noopener">Upcoming</a>
          <a href="{{ site.mainSite }}/library/" target="_blank" rel="noopener">Library</a>
          <a href="{{ site.mainSite }}/contact/" target="_blank" rel="noopener">Contact</a>
        </nav>

        <nav class="footer-col" aria-label="Connect">
          <h3 class="footer-col-title">Connect</h3>
          <a href="{{ social.instagram }}" target="_blank" rel="noopener">Instagram</a>
          <a href="{{ social.whatsapp }}" target="_blank" rel="noopener">WhatsApp Community</a>
          <a href="{{ social.youtube }}" target="_blank" rel="noopener">YouTube</a>
        </nav>
      </div>

      <div class="footer-legal">
        <p>&copy; {{ site.year }} Improvlore. All rights reserved.</p>
        <p>Based in Bangalore, India. Part of <a href="{{ site.mainSite }}/" target="_blank" rel="noopener">improvlore.com</a></p>
      </div>
    </div>
  </footer>

  {# Lightbox overlay: a single reusable container the script fills with the
     clicked image. Hidden until opened. Lives at the end of <body> so it sits
     above page content. #}
  <div class="lightbox" id="lightbox" role="dialog" aria-modal="true" aria-label="Image viewer" hidden>
    <button class="lightbox-close" type="button" aria-label="Close image">&times;</button>
    <img class="lightbox-img" src="" alt="">
  </div>

  <script>
    // Mobile nav: the hamburger toggles the dropdown panel. Keeps aria-expanded
    // in sync, closes on Escape, on click outside, and after a link is tapped.
    (function () {
      const toggle = document.querySelector(".site-nav-toggle");
      const nav = document.getElementById("site-nav");
      if (!toggle || !nav) return;

      const setOpen = (open) => {
        toggle.setAttribute("aria-expanded", open ? "true" : "false");
        toggle.setAttribute("aria-label", open ? "Close menu" : "Open menu");
        nav.classList.toggle("is-open", open);
      };

      toggle.addEventListener("click", function () {
        setOpen(toggle.getAttribute("aria-expanded") !== "true");
      });

      nav.addEventListener("click", function (e) {
        if (e.target.closest(".site-nav-link")) setOpen(false);
      });

      document.addEventListener("keydown", function (e) {
        if (e.key === "Escape") setOpen(false);
      });

      document.addEventListener("click", function (e) {
        if (toggle.getAttribute("aria-expanded") !== "true") return;
        if (!e.target.closest(".site-header")) setOpen(false);
      });
    })();

    // Justified collage rows (`:::collage row`). To fill the row edge-to-edge
    // without cropping, each image's flex item must grow in proportion to the
    // image's aspect ratio — which we only know once the image has loaded. For
    // every image in a `.collage-row`, set its <p> wrapper's flex-grow to the
    // natural width/height ratio. Flexbox then lays the row out so all images
    // share a height and the widths fill the column. Without JS the CSS
    // fallback (equal height, natural widths) still gives a tidy row.
    (function () {
      const apply = (img) => {
        const cell = img.closest(".collage-row > p");
        if (!cell || !img.naturalWidth || !img.naturalHeight) return;
        const ratio = img.naturalWidth / img.naturalHeight;
        cell.style.flexGrow = ratio.toFixed(4);
        cell.style.flexBasis = "0";
      };
      document.querySelectorAll(".collage-row img").forEach((img) => {
        if (img.complete) apply(img);
        else img.addEventListener("load", () => apply(img), { once: true });
      });
    })();

    // Lightbox: click any image in a post body to view it larger in an overlay.
    // Close by clicking the backdrop / close button or pressing Escape. Uses one
    // shared overlay element; we just swap in the clicked image's src + alt.
    (function () {
      const box = document.getElementById("lightbox");
      if (!box) return;
      const img = box.querySelector(".lightbox-img");

      const open = (src, alt) => {
        img.src = src;
        img.alt = alt || "";
        box.hidden = false;
        document.body.style.overflow = "hidden"; // lock scroll behind the overlay
      };
      const close = () => {
        box.hidden = true;
        img.src = "";
        document.body.style.overflow = "";
      };

      // Delegate clicks: any <img> inside a .post-body opens the lightbox.
      document.addEventListener("click", function (e) {
        const target = e.target.closest(".post-body img");
        if (target) { open(target.currentSrc || target.src, target.alt); return; }
        // Clicking the backdrop or the close button closes it.
        if (e.target.closest(".lightbox") && !e.target.closest(".lightbox-img")) close();
      });

      document.addEventListener("keydown", function (e) {
        if (e.key === "Escape" && !box.hidden) close();
      });
    })();
  </script>
</body>
</html>
